{
  "layer": "top",
  "position": "top",
  "height": 24,
  "spacing": 0,
  "exclusive": true,
  "fixed-center": true,

  "modules-left": [
    "hyprland/workspaces",
    "clock"
  ],

  "modules-center": [],

  "modules-right": [
    "custom/sysinfo",
    "custom/cpu_mode",            
    "custom/brightness",
    "pulseaudio",
    "network",
    "custom/battery",
    "custom/control-center",
    "tray",
    "custom/powerquick"
  ],

  "hyprland/workspaces": {
    "format": "{id}",
    "on-click": "activate",
    "sort-by-number": true,
    "active-only": false,
    "all-outputs": false
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%A %d %B %Y  //  %H:%M:%S}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "interval": 1
  },

  "custom/sysinfo": {
    "exec": "~/.config/waybar/sysinfo.sh",
    "escape": false,
    "interval": 2,
    "tooltip": false,
    "on-click": "~/.config/waybar/open-system-monitor-overlay.sh"
  },

  "custom/cpu_mode": {
    "exec": "~/.config/waybar/cpu_mode.sh",
    "return-type": "json",
    "format": "{text}",
    "escape": false,
    "interval": 2,
    "tooltip": false,
    "on-click": "~/.config/waybar/open-cpu-settings.sh",
    "on-click-right": "~/.config/waybar/cpu_mode.sh click-cpu"
  },

  "custom/brightness": {
    "exec": "~/.config/waybar/brightness-status.sh",
    "interval": 2,
    "tooltip": false,
    "on-click": "~/.config/waybar/brightness-step.sh down",
    "on-click-right": "~/.config/waybar/brightness-step.sh up"
  },

  "pulseaudio": {
    "format": "<span size='140%'></span> {volume}%",
    "format-muted": "<span size='140%'></span> MUTE",
    "on-click": "pgrep -x pavucontrol-qt >/dev/null && pkill -x pavucontrol-qt || pavucontrol-qt",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%",
    "tooltip": false
  },

  "network": {
    "format-wifi": "<span size='140%'></span> {signalStrength}%",
    "format-ethernet": "<span size='140%'></span> ETH",
    "format-disconnected": "<span size='140%'></span> NO NET",
    "tooltip-format-wifi": "{essid} — {signalStrength}%\n{ipaddr}",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
    "on-click": "pgrep -f 'kcmshell6 kcm_networkmanagement' >/dev/null && pkill -f 'kcmshell6 kcm_networkmanagement' || kcmshell6 kcm_networkmanagement",
    "interval": 10
  },

  "custom/battery": {
    "exec": "~/.config/waybar/battery-status.sh",
    "return-type": "json",
    "escape": false,
    "interval": 10,
    "on-click": "~/.config/waybar/open-battery-settings.sh",
    "on-click-right": "~/.config/waybar/cpu_mode.sh click-charge"
  },

  "custom/control-center": {
    "exec": "swaync-client -swb",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "none": "",
      "notification": "",
      "dnd-none": "",
      "dnd-notification": ""
    },
    "on-click": "sh -c 'pgrep -x swaync >/dev/null || (swaync >/dev/null 2>&1 & sleep 0.3); swaync-client -t'",
    "on-click-right": "swaync-client -d",
    "on-click-middle": "swaync-client -C"
  },

  "custom/powerquick": {
    "format": "⏻",
    "tooltip": true,
    "tooltip-format": "Left click: Logout\\nRight click: Shutdown",
    "on-click": "bash ~/.config/waybar/power-quick.sh logout",
    "on-click-right": "bash ~/.config/waybar/power-quick.sh shutdown",
    "on-click-middle": "bash ~/.config/waybar/power-quick.sh reboot"
  },

  "tray": {
    "icon-size": 20,
    "spacing": 10,
    "show-passive-items": true
  }
}