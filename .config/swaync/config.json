{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "layer-shell": true,
  "cssPriority": "user",
  "control-center-width": 300,
  "control-center-height": 600,
  "notification-window-width": 300,
  "timeout": 6,
  "timeout-low": 2,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "relative-timestamps": true,
  "notification-grouping": true,
  "transition-time": 200,
  "hide-on-clear": true,
  "widgets": [
    "title",
    "dnd",
    "buttons-grid",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰎟"
    },
    "dnd": {
      "text": "Silence"
    },
    "mpris": {
      "autohide": true,
      "show-album-art": true
    },
    "buttons-grid": {
      "buttons-per-row": 4,
      "actions": [
        { "label": "󰓃", "command": "~/.config/swaync/actions.sh audio" },
        { "label": "󰝟", "command": "~/.config/swaync/actions.sh mute" },
        { "label": "󰖩", "type": "toggle", "active": true, "command": "~/.config/swaync/actions.sh wifi-toggle" },
        { "label": "󰂯", "command": "~/.config/swaync/actions.sh bluetooth" },
        { "label": "", "command": "~/.config/swaync/actions.sh lock" },
        { "label": "󰍃", "command": "~/.config/swaync/actions.sh logout" },
        { "label": "󰑓", "command": "~/.config/swaync/actions.sh reboot" },
        { "label": "󰐥", "command": "~/.config/swaync/actions.sh shutdown" }
      ]
    }
  }
}